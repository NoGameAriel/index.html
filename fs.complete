<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Field & Signal — Complete Architecture</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Source+Code+Pro:wght@300;400;500;600&display=swap');

/* ============================================================
SHARED VARIABLES
============================================================ */
:root {
/* Dark palette (guide + schematic) */
–bg: #080a08;
–surface: #0c0f0c;
–border: #1c221c;
–border-bright: #2a342a;
–signal: #4ade80;
–signal-dim: #1a4a2a;
–signal-faint: #0d1f0d;
–signal-mid: #2d7a4a;
–text: #ccd8cc;
–text-mid: #7a9a7a;
–text-dim: #3d5c3d;
–text-muted: #253825;
–amber: #f59e0b;
–amber-dim: #3d2800;
–amber-faint: #1a1000;
–red-dim: #3d0000;
–red-faint: #1a0000;
–red: #ef4444;
–white: #e8f0e8;
/* Paper palette (layer 0) */
–paper: #f5f0e8;
–paper-dark: #ede8dc;
–paper-mid: #e8e2d4;
–ink: #1a1a16;
–ink-mid: #4a4a3e;
–ink-light: #8a8a72;
–rule: #d4ceb8;
–l0: #2d1b69;
–l0-mid: #6b4fb5;
–l0-light: #e8e0f8;
–l0-faint: #f4f0fc;
–l1: #1a4a2e; –l1-mid: #2d7a4a; –l1-light: #e0f0e8;
–l2: #1a2e4a; –l2-mid: #2d4a7a; –l2-light: #e0e8f0;
–l3: #4a2e1a; –l3-mid: #7a4a2d; –l3-light: #f0e8e0;
–l4: #3d1a3d; –l4-mid: #7a2d7a; –l4-light: #f0e0f0;
–warm: #7a4a2d;
–warm-light: #f5ede6;
}

- { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

/* ============================================================
SECTION WRAPPERS
============================================================ */
.section-schematic { background: var(–paper-dark); }
.section-layer0 { background: var(–paper-dark); }
.section-guide { background: var(–bg); }

/* NAV BAR (screen only) */
.top-nav {
position: sticky;
top: 0;
z-index: 100;
background: #0a0c0a;
border-bottom: 1px solid #1c221c;
display: flex;
align-items: center;
padding: 0.7rem 2rem;
gap: 2rem;
flex-wrap: wrap;
}

.nav-brand {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.2em;
color: var(–signal-mid);
text-transform: uppercase;
flex: 1;
}

.nav-links {
display: flex;
gap: 0;
}

.nav-link {
background: none;
border: none;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.58rem;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–text-dim);
cursor: pointer;
padding: 0.4rem 0.8rem;
border-left: 1px solid var(–border);
transition: color 0.15s, background 0.15s;
}

.nav-link:hover { color: var(–signal); background: var(–signal-faint); }
.nav-link.active { color: var(–signal); }

/* ============================================================
SCHEMATIC SECTION
============================================================ */
#section-schematic {
padding: 2.5rem 1.5rem 3rem;
}

.sch-header {
max-width: 1300px;
margin: 0 auto 1.8rem;
padding-bottom: 1.2rem;
border-bottom: 2px solid var(–ink);
display: flex;
justify-content: space-between;
align-items: flex-end;
flex-wrap: wrap;
gap: 1rem;
}

.sch-label { font-family: ‘Source Code Pro’, monospace; font-size: 0.58rem; letter-spacing: 0.25em; color: var(–ink-light); text-transform: uppercase; margin-bottom: 0.3rem; }
.sch-title { font-family: ‘Libre Baskerville’, serif; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; color: var(–ink); }
.sch-subtitle { font-family: ‘Libre Baskerville’, serif; font-size: 0.82rem; color: var(–ink-mid); font-style: italic; margin-top: 0.2rem; }
.sch-meta { font-family: ‘Source Code Pro’, monospace; font-size: 0.55rem; color: var(–ink-light); line-height: 1.8; text-align: right; }

.sch-entry {
max-width: 1300px;
margin: 0 auto 1.8rem;
padding: 1rem 1.4rem;
border-left: 3px solid var(–ink);
background: var(–paper);
font-family: ‘Libre Baskerville’, serif;
font-size: 0.88rem;
color: var(–ink-mid);
font-style: italic;
line-height: 1.6;
}
.sch-entry strong { color: var(–ink); font-style: normal; }

.sch-wrap { max-width: 1300px; margin: 0 auto; overflow-x: auto; padding-bottom: 1rem; }

.sch-flow {
min-width: 1000px;
display: flex;
align-items: stretch;
gap: 0;
}

.sch-arrow {
width: 2.8rem;
flex-shrink: 0;
display: flex;
align-items: center;
justify-content: center;
position: relative;
}
.sch-arrow-line { position: absolute; top: 50%; left: 0; right: 0; height: 1px; transform: translateY(-50%); }
.sch-arrow-head { position: absolute; right: 1px; top: 50%; transform: translateY(-50%); width: 0; height: 0; border-top: 5px solid transparent; border-bottom: 5px solid transparent; border-left: 8px solid; }
.sch-arrow-label { position: absolute; top: calc(50% - 16px); left: 50%; transform: translateX(-50%); font-family: ‘Source Code Pro’, monospace; font-size: 0.38rem; letter-spacing: 0.08em; text-transform: uppercase; white-space: nowrap; background: var(–paper-dark); padding: 0 2px; }

.sch-arrow[data-from=“0”] .sch-arrow-line { background: var(–l0-mid); }
.sch-arrow[data-from=“0”] .sch-arrow-head { border-left-color: var(–l0-mid); }
.sch-arrow[data-from=“0”] .sch-arrow-label { color: var(–l0-mid); }
.sch-arrow[data-from=“1”] .sch-arrow-line { background: var(–l1-mid); }
.sch-arrow[data-from=“1”] .sch-arrow-head { border-left-color: var(–l1-mid); }
.sch-arrow[data-from=“1”] .sch-arrow-label { color: var(–l1-mid); }
.sch-arrow[data-from=“2”] .sch-arrow-line { background: var(–l2-mid); }
.sch-arrow[data-from=“2”] .sch-arrow-head { border-left-color: var(–l2-mid); }
.sch-arrow[data-from=“2”] .sch-arrow-label { color: var(–l2-mid); }
.sch-arrow[data-from=“3”] .sch-arrow-line { background: var(–l3-mid); }
.sch-arrow[data-from=“3”] .sch-arrow-head { border-left-color: var(–l3-mid); }
.sch-arrow[data-from=“3”] .sch-arrow-label { color: var(–l3-mid); }

.sch-node { flex: 1; min-width: 0; display: flex; flex-direction: column; }

.sch-card {
border: 1.5px solid;
background: var(–paper);
height: 100%;
display: flex;
flex-direction: column;
}

.sch-card-header { padding: 0.7rem 0.8rem 0.5rem; border-bottom: 1px solid; display: flex; align-items: flex-start; gap: 0.5rem; }
.sch-num { font-family: ‘Source Code Pro’, monospace; font-size: 0.55rem; font-weight: 500; padding: 0.15rem 0.3rem; border: 1px solid; border-radius: 2px; flex-shrink: 0; margin-top: 0.1rem; background: white; }
.sch-layer-label { font-family: ‘Source Code Pro’, monospace; font-size: 0.46rem; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 0.1rem; }
.sch-name { font-family: ‘Libre Baskerville’, serif; font-size: 0.88rem; font-weight: 700; line-height: 1.2; }
.sch-question { padding: 0.45rem 0.8rem; font-family: ‘Libre Baskerville’, serif; font-size: 0.65rem; font-style: italic; color: var(–ink-mid); line-height: 1.4; border-bottom: 1px solid; flex-shrink: 0; }
.sch-body { padding: 0.6rem 0.8rem; flex: 1; }
.sch-function { font-family: ‘Source Code Pro’, monospace; font-size: 0.46rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.4rem; }
.sch-footer { padding: 0.35rem 0.8rem; border-top: 1px dashed; font-family: ‘Source Code Pro’, monospace; font-size: 0.44rem; letter-spacing: 0.06em; text-transform: uppercase; display: flex; justify-content: space-between; opacity: 0.6; }

.sch-node[data-layer=“0”] .sch-card { border-color: var(–l0); background: #eee8f8; }
.sch-node[data-layer=“0”] .sch-card-header { border-color: rgba(45,27,105,0.2); }
.sch-node[data-layer=“0”] .sch-num { color: var(–l0); border-color: var(–l0); }
.sch-node[data-layer=“0”] .sch-layer-label { color: var(–l0-mid); }
.sch-node[data-layer=“0”] .sch-name { color: var(–l0); }
.sch-node[data-layer=“0”] .sch-question { border-color: rgba(45,27,105,0.15); color: var(–l0-mid); }
.sch-node[data-layer=“0”] .sch-function { color: var(–l0-mid); }

.sch-node[data-layer=“1”] .sch-card { border-color: var(–l1); background: var(–l1-light); }
.sch-node[data-layer=“1”] .sch-card-header { border-color: rgba(26,74,46,0.2); }
.sch-node[data-layer=“1”] .sch-num { color: var(–l1); border-color: var(–l1); }
.sch-node[data-layer=“1”] .sch-layer-label { color: var(–l1-mid); }
.sch-node[data-layer=“1”] .sch-name { color: var(–l1); }
.sch-node[data-layer=“1”] .sch-question { border-color: rgba(26,74,46,0.15); color: var(–l1-mid); }
.sch-node[data-layer=“1”] .sch-function { color: var(–l1-mid); }

.sch-node[data-layer=“2”] .sch-card { border-color: var(–l2); background: var(–l2-light); }
.sch-node[data-layer=“2”] .sch-card-header { border-color: rgba(26,46,74,0.2); }
.sch-node[data-layer=“2”] .sch-num { color: var(–l2); border-color: var(–l2); }
.sch-node[data-layer=“2”] .sch-layer-label { color: var(–l2-mid); }
.sch-node[data-layer=“2”] .sch-name { color: var(–l2); }
.sch-node[data-layer=“2”] .sch-question { border-color: rgba(26,46,74,0.15); color: var(–l2-mid); }
.sch-node[data-layer=“2”] .sch-function { color: var(–l2-mid); }

.sch-node[data-layer=“3”] .sch-card { border-color: var(–l3); background: var(–l3-light); }
.sch-node[data-layer=“3”] .sch-card-header { border-color: rgba(74,46,26,0.2); }
.sch-node[data-layer=“3”] .sch-num { color: var(–l3); border-color: var(–l3); }
.sch-node[data-layer=“3”] .sch-layer-label { color: var(–l3-mid); }
.sch-node[data-layer=“3”] .sch-name { color: var(–l3); }
.sch-node[data-layer=“3”] .sch-question { border-color: rgba(74,46,26,0.15); color: var(–l3-mid); }
.sch-node[data-layer=“3”] .sch-function { color: var(–l3-mid); }

.sch-node[data-layer=“4”] .sch-card { border-color: var(–l4); background: var(–l4-light); }
.sch-node[data-layer=“4”] .sch-card-header { border-color: rgba(61,26,61,0.2); }
.sch-node[data-layer=“4”] .sch-num { color: var(–l4); border-color: var(–l4); }
.sch-node[data-layer=“4”] .sch-layer-label { color: var(–l4-mid); }
.sch-node[data-layer=“4”] .sch-name { color: var(–l4); }
.sch-node[data-layer=“4”] .sch-question { border-color: rgba(61,26,61,0.15); color: var(–l4-mid); }
.sch-node[data-layer=“4”] .sch-function { color: var(–l4-mid); }

.pairs-mini { display: flex; flex-direction: column; gap: 0.3rem; }
.pair-mini { display: grid; grid-template-columns: 1fr 1fr; border: 1px solid rgba(45,27,105,0.15); border-radius: 2px; overflow: hidden; font-size: 0.56rem; line-height: 1.3; }
.pair-mini-felt { padding: 0.3rem 0.4rem; background: var(–warm-light); border-right: 1px solid rgba(45,27,105,0.1); color: var(–warm); font-style: italic; font-family: ‘Libre Baskerville’, serif; }
.pair-mini-axm { padding: 0.3rem 0.4rem; background: rgba(255,255,255,0.5); color: var(–l0); font-family: ‘Source Code Pro’, monospace; font-size: 0.48rem; }
.pair-mini-label { font-family: ‘Source Code Pro’, monospace; font-size: 0.36rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.5; display: block; margin-bottom: 0.12rem; }

.sch-phases { display: flex; flex-direction: column; gap: 0.28rem; }
.sch-phase { display: flex; align-items: baseline; gap: 0.35rem; font-size: 0.6rem; line-height: 1.3; }
.sch-phase-letter { font-family: ‘Source Code Pro’, monospace; font-size: 0.44rem; font-weight: 500; flex-shrink: 0; opacity: 0.5; }
.sch-phase-text { font-family: ‘IBM Plex Sans’, sans-serif; color: var(–ink-mid); }

.sch-annotations { max-width: 1300px; margin: 1.8rem auto 0; display: flex; gap: 1rem; flex-wrap: wrap; padding-top: 1.2rem; border-top: 1px solid var(–rule); }
.sch-annotation { flex: 1; min-width: 150px; font-size: 0.62rem; color: var(–ink-mid); line-height: 1.55; font-family: ‘Source Code Pro’, monospace; }
.sch-annotation strong { display: block; color: var(–ink); font-size: 0.52rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.3rem; padding-bottom: 0.3rem; border-bottom: 1px solid var(–rule); }

/* ============================================================
LAYER 0 SECTION
============================================================ */
#section-layer0 {
padding: 3rem 1.5rem 4rem;
border-top: 3px solid var(–ink);
}

.l0-document { max-width: 720px; margin: 0 auto; background: var(–paper); border: 1px solid var(–rule); box-shadow: 0 4px 40px rgba(0,0,0,0.08); }

.l0-cover { padding: 3rem 3rem 2.5rem; border-bottom: 2px solid var(–ink); }
.l0-cover-meta { font-family: ‘Source Code Pro’, monospace; font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(–ink-light); margin-bottom: 2rem; display: flex; justify-content: space-between; }
.l0-layer-label { font-family: ‘Source Code Pro’, monospace; font-size: 0.62rem; letter-spacing: 0.15em; color: var(–l0-mid); text-transform: uppercase; margin-bottom: 0.5rem; }
.l0-title { font-family: ‘Libre Baskerville’, serif; font-size: 1.9rem; font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: var(–l0); margin-bottom: 0.8rem; }
.l0-subtitle { font-family: ‘Libre Baskerville’, serif; font-size: 0.95rem; font-style: italic; color: var(–ink-mid); margin-bottom: 2rem; line-height: 1.5; }
.l0-statement { font-family: ‘Libre Baskerville’, serif; font-size: 0.85rem; color: var(–ink-mid); line-height: 1.7; padding: 1.2rem 1.5rem; border-left: 3px solid var(–l0); background: var(–l0-faint); font-style: italic; }

.l0-section { padding: 2rem 3rem; border-bottom: 1px solid var(–rule); }
.l0-section-label { font-family: ‘Source Code Pro’, monospace; font-size: 0.52rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(–ink-light); margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(–rule); }
.l0-section-intro { font-family: ‘Libre Baskerville’, serif; font-size: 0.85rem; color: var(–ink-mid); line-height: 1.7; }

.l0-bridge { padding: 1.8rem 3rem; background: var(–paper-mid); border-top: 1px solid var(–rule); border-bottom: 1px solid var(–rule); text-align: center; }
.l0-bridge-text { font-family: ‘Libre Baskerville’, serif; font-size: 0.8rem; color: var(–ink-mid); line-height: 1.7; font-style: italic; max-width: 500px; margin: 0 auto; }
.l0-bridge-divider { font-family: ‘Source Code Pro’, monospace; font-size: 0.58rem; letter-spacing: 0.3em; color: var(–l0-mid); text-transform: uppercase; margin: 0.8rem 0; }

.l0-pairs { display: flex; flex-direction: column; gap: 0; }
.l0-pair { border-bottom: 1px solid var(–rule); overflow: hidden; }
.l0-pair:last-child { border-bottom: none; }
.l0-pair-number { font-family: ‘Source Code Pro’, monospace; font-size: 0.52rem; letter-spacing: 0.2em; color: var(–l0-mid); text-transform: uppercase; padding: 1.1rem 3rem 0; }
.l0-pair-body { display: grid; grid-template-columns: 1fr 1fr; }
.l0-principle-side { padding: 0.7rem 1.5rem 1.4rem 3rem; border-right: 1px solid var(–rule); background: var(–warm-light); }
.l0-axiom-side { padding: 0.7rem 3rem 1.4rem 1.5rem; background: var(–l0-faint); }
.l0-side-label { font-family: ‘Source Code Pro’, monospace; font-size: 0.46rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 0.4rem; }
.l0-principle-side .l0-side-label { color: var(–warm); }
.l0-axiom-side .l0-side-label { color: var(–l0-mid); }
.l0-principle-name { font-family: ‘Libre Baskerville’, serif; font-size: 0.88rem; font-weight: 700; color: var(–warm); line-height: 1.3; margin-bottom: 0.35rem; }
.l0-principle-desc { font-family: ‘IBM Plex Sans’, sans-serif; font-size: 0.7rem; color: var(–ink-mid); line-height: 1.5; font-style: italic; }
.l0-axiom-statement { font-family: ‘Libre Baskerville’, serif; font-size: 0.82rem; font-weight: 700; color: var(–l0); line-height: 1.3; margin-bottom: 0.35rem; }
.l0-axiom-meaning { font-family: ‘Source Code Pro’, monospace; font-size: 0.62rem; font-weight: 300; color: var(–ink-mid); line-height: 1.5; }

.l0-closing { padding: 2.5rem 3rem; }
.l0-closing-title { font-family: ‘Libre Baskerville’, serif; font-size: 1rem; font-weight: 700; color: var(–l0); margin-bottom: 0.8rem; }
.l0-closing-text { font-family: ‘Libre Baskerville’, serif; font-size: 0.82rem; color: var(–ink-mid); line-height: 1.8; margin-bottom: 1rem; }
.l0-version-note { font-family: ‘Source Code Pro’, monospace; font-size: 0.6rem; color: var(–ink-light); line-height: 1.6; padding: 1rem 1.2rem; border: 1px solid var(–rule); background: var(–paper-mid); }

.l0-footer { padding: 0.9rem 3rem; border-top: 1px solid var(–rule); display: flex; justify-content: space-between; align-items: center; background: var(–paper-mid); }
.l0-footer-sig { font-family: ‘Source Code Pro’, monospace; font-size: 0.5rem; letter-spacing: 0.1em; color: var(–ink-light); }
.l0-footer-ver { font-family: ‘Source Code Pro’, monospace; font-size: 0.5rem; color: var(–l0-mid); letter-spacing: 0.1em; }

/* ============================================================
GUIDE SECTION
============================================================ */
#section-guide {
border-top: 3px solid var(–signal-dim);
min-height: 100vh;
display: flex;
flex-direction: column;
}

.guide-header { padding: 1.2rem 2rem; border-bottom: 1px solid var(–border); display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
.guide-sys-id { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.55rem; letter-spacing: 0.25em; color: var(–text-dim); text-transform: uppercase; }
.guide-status { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.55rem; letter-spacing: 0.15em; color: var(–signal-mid); text-transform: uppercase; }

.guide-screens { flex: 1; position: relative; }

.g-screen { display: none; flex-direction: column; }
.g-screen.active { display: flex; }

.g-body { flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 3rem 2rem; max-width: 680px; margin: 0 auto; width: 100%; }

.g-entry-mark { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.58rem; letter-spacing: 0.3em; color: var(–signal-mid); text-transform: uppercase; margin-bottom: 2rem; }
.g-entry-mark span { display: inline-block; width: 1.5rem; height: 1px; background: var(–signal-mid); vertical-align: middle; margin-right: 0.8rem; }

.g-title { font-family: ‘IBM Plex Mono’, monospace; font-size: 1.5rem; font-weight: 600; color: var(–white); line-height: 1.2; margin-bottom: 0.8rem; letter-spacing: -0.02em; }
.g-sub { font-family: ‘IBM Plex Sans’, sans-serif; font-size: 0.78rem; color: var(–text-mid); margin-bottom: 3rem; line-height: 1.7; font-style: italic; }
.g-prompt { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.7rem; color: var(–text-mid); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.2rem; }

.g-choices { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 2rem; }
.g-choice { background: none; border: 1px solid var(–border-bright); color: var(–text); font-family: ‘IBM Plex Mono’, monospace; font-size: 0.75rem; padding: 1rem 1.2rem; text-align: left; cursor: pointer; transition: all 0.15s; line-height: 1.4; position: relative; }
.g-choice::before { content: ‘’; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: transparent; transition: background 0.15s; }
.g-choice:hover { border-color: var(–signal-dim); background: var(–signal-faint); }
.g-choice:hover::before { background: var(–signal); }
.g-choice-label { font-size: 0.52rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(–text-dim); display: block; margin-bottom: 0.3rem; }
.g-choice:hover .g-choice-label { color: var(–signal-mid); }
.g-choice-text { font-size: 0.82rem; color: var(–text); font-style: italic; display: block; margin-bottom: 0.2rem; }
.g-choice:hover .g-choice-text { color: var(–signal); }
.g-choice-sub { font-family: ‘IBM Plex Sans’, sans-serif; font-size: 0.6rem; color: var(–text-dim); display: block; }
.g-choice:hover .g-choice-sub { color: var(–text-mid); }

.g-dtag { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.52rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 0.3rem 0.6rem; border: 1px solid; display: inline-block; margin-bottom: 1.5rem; }
.g-dtag.loop { color: var(–signal); border-color: var(–signal-dim); background: var(–signal-faint); }
.g-dtag.capacity { color: var(–amber); border-color: var(–amber-dim); background: var(–amber-faint); }
.g-dtag.perception { color: #60a5fa; border-color: #1a2e4a; background: #0a1520; }
.g-dtag.signal { color: #c084fc; border-color: #2d1a4a; background: #12091f; }

.g-confirm { font-family: ‘IBM Plex Sans’, sans-serif; font-size: 0.78rem; color: var(–text-mid); line-height: 1.7; margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(–border); font-style: italic; }

.g-misread { margin-bottom: 2rem; padding: 1rem 1.2rem; border: 1px solid var(–amber-dim); background: var(–amber-faint); }
.g-misread-label { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.48rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(–amber); margin-bottom: 0.6rem; }
.g-misread-text { font-family: ‘IBM Plex Sans’, sans-serif; font-size: 0.7rem; color: var(–text-mid); line-height: 1.6; }
.g-misread-text strong { color: var(–amber); font-family: ‘IBM Plex Mono’, monospace; font-size: 0.66rem; }

.g-route-label { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.48rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(–text-dim); margin-bottom: 0.8rem; }
.g-route-steps { display: flex; flex-direction: column; gap: 0; margin-bottom: 2rem; }
.g-step { display: grid; grid-template-columns: 2rem 1fr; gap: 0 1rem; padding: 0.8rem 0; border-bottom: 1px solid var(–border); }
.g-step:last-child { border-bottom: none; }
.g-step-num { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.52rem; color: var(–text-dim); padding-top: 0.15rem; font-weight: 600; }
.g-step-instrument { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.75rem; color: var(–white); margin-bottom: 0.2rem; font-weight: 500; }
.g-step-action { font-family: ‘IBM Plex Sans’, sans-serif; font-size: 0.62rem; color: var(–text-mid); line-height: 1.5; margin-bottom: 0.2rem; }
.g-step-signal { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.56rem; color: var(–signal-mid); }
.g-step-signal::before { content: ’→ ’; }

.g-exit { padding: 1rem 1.2rem; border: 1px solid var(–signal-dim); background: var(–signal-faint); margin-bottom: 2rem; }
.g-exit-label { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.48rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(–signal); margin-bottom: 0.5rem; }
.g-exit-text { font-family: ‘IBM Plex Sans’, sans-serif; font-size: 0.7rem; color: var(–text-mid); line-height: 1.6; }
.g-exit-text strong { color: var(–signal); font-family: ‘IBM Plex Mono’, monospace; font-size: 0.66rem; }

.g-caution { padding: 0.8rem 1rem; border: 1px solid var(–red-dim); background: var(–red-faint); margin-bottom: 2rem; }
.g-caution-label { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.46rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(–red); margin-bottom: 0.4rem; }
.g-caution-text { font-family: ‘IBM Plex Sans’, sans-serif; font-size: 0.65rem; color: var(–text-mid); line-height: 1.5; }

.g-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
.g-btn-primary { background: var(–signal-faint); border: 1px solid var(–signal-dim); color: var(–signal); font-family: ‘IBM Plex Mono’, monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.7rem 1.2rem; cursor: pointer; transition: all 0.15s; }
.g-btn-primary:hover { background: var(–signal-dim); border-color: var(–signal); }
.g-btn-ghost { background: none; border: 1px solid var(–border-bright); color: var(–text-dim); font-family: ‘IBM Plex Mono’, monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.7rem 1.2rem; cursor: pointer; transition: all 0.15s; }
.g-btn-ghost:hover { border-color: var(–text-mid); color: var(–text); }

.guide-footer { padding: 1rem 2rem; border-top: 1px solid var(–border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
.g-footer-note { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.48rem; color: var(–text-muted); letter-spacing: 0.1em; }
.g-footer-back { background: none; border: none; color: var(–text-dim); font-family: ‘IBM Plex Mono’, monospace; font-size: 0.48rem; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; transition: color 0.15s; }
.g-footer-back:hover { color: var(–text); }

/* ============================================================
PRINT STYLES
============================================================ */
@media print {

- { -webkit-print-color-adjust: exact; print-color-adjust: exact; }

.top-nav { display: none !important; }

/* Schematic prints as-is, just flow it */
#section-schematic {
padding: 1.5rem;
page-break-after: always;
}

.sch-wrap { overflow: visible; }
.sch-flow {
min-width: 0;
flex-wrap: wrap;
gap: 0.5rem;
}
.sch-node { min-width: 140px; flex: 1; }
.sch-arrow { width: 1.5rem; }
.sch-arrow-label { display: none; }

/* Layer 0 prints cleanly */
#section-layer0 {
padding: 1.5rem;
page-break-after: always;
}
.l0-document { box-shadow: none; border: none; }
.l0-pair-body { grid-template-columns: 1fr 1fr; }

/* Guide prints as linear document */
#section-guide {
min-height: 0;
page-break-before: always;
}

.guide-header { border-bottom: 2px solid #1c221c; }

/* Show all screens, hide interactive elements */
.g-screen { display: block !important; page-break-inside: avoid; border-bottom: 1px solid #1c221c; padding-bottom: 2rem; margin-bottom: 2rem; }

.g-body { padding: 1.5rem; max-width: 100%; justify-content: flex-start; }

.g-choices { gap: 0.4rem; }
.g-choice { border-color: #2a342a; padding: 0.7rem 1rem; }
.g-choice::before { display: none; }

/* Hide nav buttons in print */
.g-actions { display: none; }
.guide-footer { display: none; }

/* Keep guide as single block */
.guide-screens { display: block; }
}

/* ============================================================
ANIMATIONS (screen only)
============================================================ */
@media screen {
.g-body > * { animation: fadeUp 0.3s ease both; }
.g-body > *:nth-child(1) { animation-delay: 0.05s; }
.g-body > *:nth-child(2) { animation-delay: 0.1s; }
.g-body > *:nth-child(3) { animation-delay: 0.15s; }
.g-body > *:nth-child(4) { animation-delay: 0.2s; }
.g-body > *:nth-child(5) { animation-delay: 0.25s; }
.g-body > *:nth-child(6) { animation-delay: 0.3s; }
.g-body > *:nth-child(7) { animation-delay: 0.35s; }

@keyframes fadeUp {
from { opacity: 0; transform: translateY(8px); }
to { opacity: 1; transform: translateY(0); }
}
}

@media (max-width: 600px) {
.l0-cover, .l0-section, .l0-closing { padding-left: 1.5rem; padding-right: 1.5rem; }
.l0-pair-number { padding-left: 1.5rem; padding-right: 1.5rem; }
.l0-pair-body { grid-template-columns: 1fr; }
.l0-principle-side { padding: 0.8rem 1.5rem; border-right: none; border-bottom: 1px solid var(–rule); }
.l0-axiom-side { padding: 0.8rem 1.5rem 1.4rem; }
.l0-bridge { padding-left: 1.5rem; padding-right: 1.5rem; }
.l0-footer { padding-left: 1.5rem; padding-right: 1.5rem; flex-direction: column; gap: 0.3rem; }
.g-body { padding: 2rem 1.2rem; }
}
</style>

</head>
<body>

<!-- NAV (screen only) -->

<nav class="top-nav">
  <div class="nav-brand">Field & Signal — Complete Architecture</div>
  <div class="nav-links">
    <button class="nav-link active" onclick="scrollTo('section-schematic', this)">Schematic</button>
    <button class="nav-link" onclick="scrollTo('section-layer0', this)">Layer 0</button>
    <button class="nav-link" onclick="scrollTo('section-guide', this)">Practitioner Guide</button>
  </div>
</nav>

<!-- ============================================================
     SECTION 1: SCHEMATIC
     ============================================================ -->

<div class="section-schematic" id="section-schematic">
  <div style="padding: 2.5rem 1.5rem 3rem;">

```
<div class="sch-header">
  <div>
    <div class="sch-label">Field & Signal — System Schematic</div>
    <div class="sch-title">A diagnostic architecture for institutional coherence</div>
    <div class="sch-subtitle">Field medicine for systems under stress</div>
  </div>
  <div class="sch-meta">April 2026 — v2.0<br>5 layers · 7 axiom pairs · 40+ instruments<br>Read left to right</div>
</div>

<div class="sch-entry">
  Most systems don't fail because of bad people. They fail because the structure stops being able to hear itself. <strong>Field & Signal</strong> is a set of tools for diagnosing why that happens, assessing whether a system can be intervened on, running that intervention, and building conditions that hold over time.
</div>

<div class="sch-wrap">
  <div class="sch-flow">

    <div class="sch-node" data-layer="0">
      <div class="sch-card">
        <div class="sch-card-header">
          <div class="sch-num">L·0</div>
          <div><div class="sch-layer-label">Foundation</div><div class="sch-name">Ontology</div></div>
        </div>
        <div class="sch-question">"What is actually true about systems and humans?"</div>
        <div class="sch-body">
          <div class="sch-function">Seven paired claims — felt + structural</div>
          <div class="pairs-mini">
            <div class="pair-mini"><div class="pair-mini-felt"><span class="pair-mini-label">Felt</span>Presence Requires Agency</div><div class="pair-mini-axm"><span class="pair-mini-label">Axiom</span>Humans are signal-processors under distortion</div></div>
            <div class="pair-mini"><div class="pair-mini-felt"><span class="pair-mini-label">Felt</span>Perception is Participatory</div><div class="pair-mini-axm"><span class="pair-mini-label">Axiom</span>The observer is never neutral</div></div>
            <div class="pair-mini"><div class="pair-mini-felt"><span class="pair-mini-label">Felt</span>Misalignment Creates Fracture</div><div class="pair-mini-axm"><span class="pair-mini-label">Axiom</span>Systems drift toward compression unless counter-looped</div></div>
            <div class="pair-mini"><div class="pair-mini-felt"><span class="pair-mini-label">Felt</span>Emotional Awareness is Infrastructure</div><div class="pair-mini-axm"><span class="pair-mini-label">Axiom</span>Pressure is inevitable — collapse is optional</div></div>
            <div class="pair-mini"><div class="pair-mini-felt"><span class="pair-mini-label">Felt</span>Intention Informs, Does Not Excuse</div><div class="pair-mini-axm"><span class="pair-mini-label">Axiom</span>Intent and impact are structurally separate</div></div>
            <div class="pair-mini"><div class="pair-mini-felt"><span class="pair-mini-label">Felt</span>Context Grounds Connection</div><div class="pair-mini-axm"><span class="pair-mini-label">Axiom</span>Context is the interpretive ground, not background</div></div>
            <div class="pair-mini"><div class="pair-mini-felt"><span class="pair-mini-label">Felt</span>The Field Remembers</div><div class="pair-mini-axm"><span class="pair-mini-label">Axiom</span>Distortion self-reinforces unless interrupted</div></div>
          </div>
        </div>
        <div class="sch-footer"><span>Ground layer</span><span>7 pairs</span></div>
      </div>
    </div>

    <div class="sch-arrow" data-from="0"><div class="sch-arrow-line"></div><div class="sch-arrow-head"></div><div class="sch-arrow-label">constrains</div></div>

    <div class="sch-node" data-layer="1">
      <div class="sch-card">
        <div class="sch-card-header">
          <div class="sch-num">L·1</div>
          <div><div class="sch-layer-label">Layer One</div><div class="sch-name">Perception</div></div>
        </div>
        <div class="sch-question">"What am I looking at — and is it workable?"</div>
        <div class="sch-body">
          <div class="sch-function">Before acting, see clearly</div>
          <div class="sch-phases">
            <div class="sch-phase"><span class="sch-phase-letter">A</span><span class="sch-phase-text">Diagnose structural failure and distortion patterns</span></div>
            <div class="sch-phase"><span class="sch-phase-letter">B</span><span class="sch-phase-text">Assess whether the system can be intervened on</span></div>
            <div class="sch-phase"><span class="sch-phase-letter">C</span><span class="sch-phase-text">Orient the practitioner — entry is calibration, not marketing</span></div>
          </div>
        </div>
        <div class="sch-footer"><span>Seeing clearly</span><span>12 instruments</span></div>
      </div>
    </div>

    <div class="sch-arrow" data-from="1"><div class="sch-arrow-line"></div><div class="sch-arrow-head"></div><div class="sch-arrow-label">enables</div></div>

    <div class="sch-node" data-layer="2">
      <div class="sch-card">
        <div class="sch-card-header">
          <div class="sch-num">L·2</div>
          <div><div class="sch-layer-label">Layer Two</div><div class="sch-name">Operation</div></div>
        </div>
        <div class="sch-question">"How does the loop actually run?"</div>
        <div class="sch-body">
          <div class="sch-function">The six-stage working cycle</div>
          <div class="sch-phases">
            <div class="sch-phase"><span class="sch-phase-letter">A</span><span class="sch-phase-text">Intake — verify what signal is actually arriving</span></div>
            <div class="sch-phase"><span class="sch-phase-letter">B</span><span class="sch-phase-text">Transform — develop and design from signal</span></div>
            <div class="sch-phase"><span class="sch-phase-letter">C</span><span class="sch-phase-text">Act — deploy into real field conditions</span></div>
            <div class="sch-phase"><span class="sch-phase-letter">D</span><span class="sch-phase-text">Reflect — diagnose and adapt before next loop</span></div>
          </div>
        </div>
        <div class="sch-footer"><span>Doing the work</span><span>14 instruments</span></div>
      </div>
    </div>

    <div class="sch-arrow" data-from="2"><div class="sch-arrow-line"></div><div class="sch-arrow-head"></div><div class="sch-arrow-label">requires</div></div>

    <div class="sch-node" data-layer="3">
      <div class="sch-card">
        <div class="sch-card-header">
          <div class="sch-num">L·3</div>
          <div><div class="sch-layer-label">Layer Three</div><div class="sch-name">Stabilization</div></div>
        </div>
        <div class="sch-question">"Will this still work under pressure and over time?"</div>
        <div class="sch-body">
          <div class="sch-function">The layer most systems forget</div>
          <div class="sch-phases">
            <div class="sch-phase"><span class="sch-phase-letter">A</span><span class="sch-phase-text">Build capacity — map what the system actually has</span></div>
            <div class="sch-phase"><span class="sch-phase-letter">B</span><span class="sch-phase-text">Repair — treat harm as feedback, not failure</span></div>
            <div class="sch-phase"><span class="sch-phase-letter">C</span><span class="sch-phase-text">Sustain — trust infrastructure that holds over time</span></div>
          </div>
        </div>
        <div class="sch-footer"><span>Making it hold</span><span>11 instruments</span></div>
      </div>
    </div>

    <div class="sch-arrow" data-from="3"><div class="sch-arrow-line"></div><div class="sch-arrow-head"></div><div class="sch-arrow-label">enables</div></div>

    <div class="sch-node" data-layer="4">
      <div class="sch-card">
        <div class="sch-card-header">
          <div class="sch-num">L·4</div>
          <div><div class="sch-layer-label">Layer Four</div><div class="sch-name">Expansion</div></div>
        </div>
        <div class="sch-question">"How does this grow without recreating the problem?"</div>
        <div class="sch-body">
          <div class="sch-function">Scale only what holds under pressure</div>
          <div class="sch-phases">
            <div class="sch-phase"><span class="sch-phase-letter">A</span><span class="sch-phase-text">Parallelization — multiple systems without collapse</span></div>
            <div class="sch-phase"><span class="sch-phase-letter">B</span><span class="sch-phase-text">System design — decentralized, ethical architecture</span></div>
            <div class="sch-phase"><span class="sch-phase-letter">C</span><span class="sch-phase-text">Long-arc direction — the world F&S is building toward</span></div>
          </div>
        </div>
        <div class="sch-footer"><span>Scaling without collapse</span><span>9 instruments</span></div>
      </div>
    </div>

  </div>
</div>

<div class="sch-annotations">
  <div class="sch-annotation"><strong>Layer 0 — Two registers</strong>Each axiom pair shows the same truth twice: how it feels and what it means structurally. A new reader enters through the felt side. A practitioner works from the structural side.</div>
  <div class="sch-annotation"><strong>Why sequence matters</strong>You cannot run Layer 2 without Layer 1 confirmed. Skipping perception and going straight to operation is why most interventions fail. The sequence is load-bearing.</div>
  <div class="sch-annotation"><strong>What Layer 3 is for</strong>Most frameworks end at deployment. F&S treats stabilization as its own layer because systems that work once but collapse under pressure are not systems — they are events.</div>
  <div class="sch-annotation"><strong>How to enter</strong>Start with the front door. Then conditions assessment. Then interruptibility. Only after those confirm field readiness do you move to operation.</div>
</div>
```

  </div>
</div>

<!-- ============================================================
     SECTION 2: LAYER 0
     ============================================================ -->

<div class="section-layer0" id="section-layer0">
  <div style="padding: 3rem 1.5rem 4rem;">
    <div class="l0-document">

```
  <div class="l0-cover">
    <div class="l0-cover-meta"><span>Field & Signal</span><span>April 2026 — v1.0</span></div>
    <div class="l0-layer-label">Layer 0 — Ontological Ground</div>
    <div class="l0-title">What Is True About Systems and Humans</div>
    <div class="l0-subtitle">The seven foundational claims that constrain everything Field & Signal is allowed to become</div>
    <div class="l0-statement">Before tools. Before diagnosis. Before intervention. There is a set of claims about how systems actually work and how humans actually function inside them. These are not philosophy. They are constraints. Change one and the entire architecture shifts. Every instrument in the Field & Signal corpus is downstream of what is written here.</div>
  </div>

  <div class="l0-section">
    <div class="l0-section-label">Part One — The Felt Layer</div>
    <div class="l0-section-intro">These seven principles are how distortion, compression, and systemic failure are experienced before they are named. They are the human entry point into the architecture. A practitioner may recognize themselves here long before they can articulate the structural mechanics. That recognition is the beginning of the work.</div>
  </div>

  <div class="l0-bridge">
    <div class="l0-bridge-text">Each principle has a structural translation. The principle is what it feels like. The axiom is what it means mechanically. Neither is more true than the other — they are two registers of the same claim.</div>
    <div class="l0-bridge-divider">— The Pairs —</div>
    <div class="l0-bridge-text">Read left to right: felt experience → structural constraint.</div>
  </div>

  <div class="l0-pairs">

    <div class="l0-pair">
      <div class="l0-pair-number">Pair 01 of 07</div>
      <div class="l0-pair-body">
        <div class="l0-principle-side"><div class="l0-side-label">Principle — Felt</div><div class="l0-principle-name">Presence Requires Agency</div><div class="l0-principle-desc">Showing up means fully — body, mind, and choice. You cannot be present by accident. Presence is an act of will against the pull of distraction, compression, and overload.</div></div>
        <div class="l0-axiom-side"><div class="l0-side-label">Axiom — Structural</div><div class="l0-axiom-statement">Humans are signal-processing systems operating under constant distortion</div><div class="l0-axiom-meaning">A human is not a fixed identity. They are a dynamic interpretation engine in a noisy field. Full presence is the active choice to receive signal clearly despite that noise.</div></div>
      </div>
    </div>

    <div class="l0-pair">
      <div class="l0-pair-number">Pair 02 of 07</div>
      <div class="l0-pair-body">
        <div class="l0-principle-side"><div class="l0-side-label">Principle — Felt</div><div class="l0-principle-name">Perception is Participatory</div><div class="l0-principle-desc">The way we see is shaped by how we show up. There is no neutral observer. What you bring into a system changes what becomes visible inside it.</div></div>
        <div class="l0-axiom-side"><div class="l0-side-label">Axiom — Structural</div><div class="l0-axiom-statement">Perception is participatory — the observer is never neutral</div><div class="l0-axiom-meaning">Diagnosis is not objective extraction. It is a co-produced reading shaped by the position, condition, and assumptions of the diagnostician. This must be designed for, not ignored.</div></div>
      </div>
    </div>

    <div class="l0-pair">
      <div class="l0-pair-number">Pair 03 of 07</div>
      <div class="l0-pair-body">
        <div class="l0-principle-side"><div class="l0-side-label">Principle — Felt</div><div class="l0-principle-name">Misalignment Creates Energetic Fracture</div><div class="l0-principle-desc">When words, actions, and energy don't match — dissonance is felt. People know before they can say it. The fracture shows up in the body, in the room, in the culture.</div></div>
        <div class="l0-axiom-side"><div class="l0-side-label">Axiom — Structural</div><div class="l0-axiom-statement">All systems drift toward compression unless actively counter-looped</div><div class="l0-axiom-meaning">Compression is identity locking, metric substitution, the hardening of complexity into categories. Misalignment is the felt signal of compression beginning. It must be interrupted before it becomes structure.</div></div>
      </div>
    </div>

    <div class="l0-pair">
      <div class="l0-pair-number">Pair 04 of 07</div>
      <div class="l0-pair-body">
        <div class="l0-principle-side"><div class="l0-side-label">Principle — Felt</div><div class="l0-principle-name">Emotional Awareness is Cultural Infrastructure</div><div class="l0-principle-desc">When care becomes culture, systems heal. Emotional awareness is not softness — it is the load-bearing material of coherent systems. Remove it and the structure eventually fails.</div></div>
        <div class="l0-axiom-side"><div class="l0-side-label">Axiom — Structural</div><div class="l0-axiom-statement">Pressure is inevitable — collapse is optional</div><div class="l0-axiom-meaning">Pressure is not dysfunction. It is system load. Emotional awareness is the mechanism that converts pressure into diagnostic data rather than rupture. Systems that suppress it become brittle.</div></div>
      </div>
    </div>

    <div class="l0-pair">
      <div class="l0-pair-number">Pair 05 of 07</div>
      <div class="l0-pair-body">
        <div class="l0-principle-side"><div class="l0-side-label">Principle — Felt</div><div class="l0-principle-name">Intention Informs, but Does Not Excuse</div><div class="l0-principle-desc">What you meant matters — but impact matters more. Good intent does not close the loop. The effect of an action on a system is the data, not the motive behind it.</div></div>
        <div class="l0-axiom-side"><div class="l0-side-label">Axiom — Structural</div><div class="l0-axiom-statement">Meaning is constructed post-event — intent and impact are structurally separate</div><div class="l0-axiom-meaning">What happened and what it means are not the same thing. Meaning is assigned after the fact, shaped by context and position. Systems that conflate intent with impact lose their ability to learn from failure.</div></div>
      </div>
    </div>

    <div class="l0-pair">
      <div class="l0-pair-number">Pair 06 of 07</div>
      <div class="l0-pair-body">
        <div class="l0-principle-side"><div class="l0-side-label">Principle — Felt</div><div class="l0-principle-name">Context Grounds Connection</div><div class="l0-principle-desc">Resonance starts with honoring truth and difference — not through erasure or avoidance. Connection that ignores context is not connection. It is projection.</div></div>
        <div class="l0-axiom-side"><div class="l0-side-label">Axiom — Structural</div><div class="l0-axiom-statement">Context is not background — it is the interpretive ground itself</div><div class="l0-axiom-meaning">Strip context and meaning collapses. Every signal is read through the conditions in which it arrives. Systems that treat context as optional produce systematically distorted interpretations.</div></div>
      </div>
    </div>

    <div class="l0-pair">
      <div class="l0-pair-number">Pair 07 of 07</div>
      <div class="l0-pair-body">
        <div class="l0-principle-side"><div class="l0-side-label">Principle — Felt</div><div class="l0-principle-name">The Field Remembers</div><div class="l0-principle-desc">All systems can experience dissonance — and all systems can tune. But the field carries what has happened in it. History is not erased by intention. It must be metabolized.</div></div>
        <div class="l0-axiom-side"><div class="l0-side-label">Axiom — Structural</div><div class="l0-axiom-statement">Distortion self-reinforces unless actively interrupted</div><div class="l0-axiom-meaning">Feedback loops amplify error. Systems encode their history into their structure. Re-signalization must account for what is already embedded — not assume a clean slate. The field remembers because the architecture does.</div></div>
      </div>
    </div>

  </div>

  <div class="l0-closing">
    <div class="l0-closing-title">What This Means for the Architecture</div>
    <div class="l0-closing-text">These seven pairs are not a philosophy section to be read once and set aside. They are operational constraints. Every diagnostic tool, every repair instrument, every deployment guide in the Field & Signal corpus was built inside the limits these axioms define.</div>
    <div class="l0-closing-text">When a practitioner finds that a tool is not working, the first question is not "is the tool broken?" It is: "which axiom is being violated in the field conditions I am working in?" The axioms are the diagnostic frame for the diagnostics themselves.</div>
    <div class="l0-version-note">Version note — April 2026: This document supersedes any prior reference to "five axioms" in the F&S corpus. The original five were underdifferentiated. Axioms 1 and 4 each carried two distinct structural claims. The seven-axiom structure was identified through the correspondence between the principles and the mechanics — the principles revealed the gap. This is the architecture self-correcting.</div>
  </div>

  <div class="l0-footer">
    <div class="l0-footer-sig">Field & Signal — Layer 0: Ontological Ground</div>
    <div class="l0-footer-ver">v1.0 — April 2026</div>
  </div>

</div>
```

  </div>
</div>

<!-- ============================================================
     SECTION 3: PRACTITIONER GUIDE
     ============================================================ -->

<div class="section-guide" id="section-guide">

  <div class="guide-header">
    <div class="guide-sys-id">Field & Signal — Practitioner Guide</div>
    <div class="guide-status" id="guide-status">Gate 1</div>
  </div>

  <div class="guide-screens">

```
<!-- GATE 1: CAUSALITY TEST -->
<div class="g-screen active" id="g-entry">
  <div class="g-body">
    <div class="g-entry-mark"><span></span>Gate 1 — Causality Test</div>
    <div class="g-title">Something is not working.<br>Existing tools have not stabilized it.</div>
    <div class="g-sub">This guide does not teach Field & Signal. It moves you from misreading your system's failure condition toward correct diagnosis, constrained intervention, and stabilized loop autonomy.<br><br>You will not be given options. You will be given a path.</div>
    <div class="g-prompt">If you replaced the people involved, would this problem persist?</div>
    <div class="g-choices">
      <button class="g-choice" onclick="gGoTo('g-exit-fs','Exiting F&S Path')">
        <span class="g-choice-label">Clearly a people problem</span>
        <span class="g-choice-text">"No — this is isolated, role-specific, non-recurring."</span>
        <span class="g-choice-sub">Different people would not produce the same failure. This is not a system problem.</span>
      </button>
      <button class="g-choice" onclick="gGoTo('g-gate2-safety','Gate 2 — Practitioner State')">
        <span class="g-choice-label">Clearly a system problem</span>
        <span class="g-choice-text">"Yes — this recurs across people and contexts."</span>
        <span class="g-choice-sub">The failure persists regardless of who is in the role. Proceed.</span>
      </button>
      <button class="g-choice" onclick="gGoTo('g-gate2-safety','Gate 2 — Practitioner State')">
        <span class="g-choice-label">Unclear</span>
        <span class="g-choice-text">"I'm not sure. It might be both."</span>
        <span class="g-choice-sub">Default to system hypothesis. Proceed with structural lens — blame is not a diagnostic tool.</span>
      </button>
    </div>
  </div>
  <div class="guide-footer">
    <div class="g-footer-note">Field & Signal — Practitioner Guide — v2.0 — April 2026</div>
    <div class="g-footer-note">Single-practitioner instrument</div>
  </div>
</div>

<!-- EXIT: NOT F&S -->
<div class="g-screen" id="g-exit-fs">
  <div class="g-body">
    <div class="g-entry-mark"><span></span>Exiting F&S Path</div>
    <div class="g-title">This appears to be a people problem,<br>not a system problem.</div>
    <div class="g-confirm">Field & Signal is a diagnostic architecture for structural failure — recurring patterns that persist across people, roles, and contexts. If replacing the people involved would resolve the failure, the tools here will not address the root condition.</div>
    <div class="g-misread" style="border-color:var(--border-bright);background:rgba(255,255,255,0.02);">
      <div class="g-misread-label" style="color:var(--text-mid);">Appropriate next steps</div>
      <div class="g-misread-text" style="color:var(--text-mid);">Handle via management, hiring, training, or role redesign. If the problem recurs after personnel change — return here. Recurrence is the signal that the system is the problem.</div>
    </div>
    <div class="g-exit">
      <div class="g-exit-label">One check before you go</div>
      <div class="g-exit-text">Has this failure appeared in a previous person in this role? If yes — <strong>this is a system problem.</strong> The role itself is producing the failure. Return to Gate 1 and proceed.</div>
    </div>
    <div class="g-actions">
      <button class="g-btn-primary" onclick="gGoTo('g-entry','Gate 1')">Return to Gate 1</button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Gate 1 — Exit</div><button class="g-footer-back" onclick="gGoTo('g-entry','Gate 1')">← Back</button></div>
</div>

<!-- GATE 2: SAFETY CHECK -->
<div class="g-screen" id="g-gate2-safety">
  <div class="g-body">
    <div class="g-entry-mark"><span></span>Gate 2 — Practitioner State · Check 1 of 4</div>
    <div class="g-title">Before diagnosing the system,<br>the practitioner must be assessed.</div>
    <div class="g-confirm" style="border-color:var(--signal-dim);padding:1rem 1.2rem;background:var(--signal-faint);margin-bottom:1.5rem;font-style:normal;font-size:0.72rem;">The practitioner is also a field. Under pressure, perception, safety, context, and agency can all distort — these preconditions exist to restore signal clarity before diagnosis begins.</div>
    <div class="g-misread" style="border-color:var(--border-bright);background:rgba(255,255,255,0.02);margin-bottom:1.5rem;">
      <div class="g-misread-label" style="color:var(--text-mid);">Ordering invariant — non-negotiable</div>
      <div class="g-misread-text" style="color:var(--text-mid);">Safety → Perception → Context → Agency → Diagnosis<br>Nothing bypasses Safety. Nothing precedes it. If you are unsafe, everything else you perceive is contaminated signal.</div>
    </div>
    <div class="g-prompt">Safety Check — Is it safe for you to engage with this system directly?</div>
    <div class="g-choices">
      <button class="g-choice" onclick="gGoTo('g-precond-safety','Precondition — Safe Mapping')">
        <span class="g-choice-label">No</span>
        <span class="g-choice-text">"Speaking or acting directly carries real risk."</span>
        <span class="g-choice-sub">Retaliation, exposure, political or structural consequence — the cost of visibility is too high right now.</span>
      </button>
      <button class="g-choice" onclick="gGoTo('g-gate2-perception','Gate 2 · Check 2 of 4')">
        <span class="g-choice-label">Yes</span>
        <span class="g-choice-text">"I can engage directly without significant risk."</span>
        <span class="g-choice-sub">You have enough standing and safety to name what you see. Proceed to perception check.</span>
      </button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Gate 2 — Safety Check</div><button class="g-footer-back" onclick="gGoTo('g-entry','Gate 1')">← Back</button></div>
</div>

<!-- PRECONDITION: SAFE MAPPING -->
<div class="g-screen" id="g-precond-safety">
  <div class="g-body">
    <div class="g-dtag" style="color:#c084fc;border-color:#2d1a4a;background:#12091f;">Precondition Loop — Safe Mapping</div>
    <div class="g-title">You are not in a diagnostic problem.<br>You are in a power and suppression problem.</div>
    <div class="g-confirm">When it is not safe to name what is happening, direct intervention becomes self-damage. The path changes completely. You do not diagnose the system openly. You map it indirectly until a safe vector exists.</div>
    <div class="g-route-label">Safe Mapping Protocol</div>
    <div class="g-route-steps">
      <div class="g-step"><div class="g-step-num">01</div><div><div class="g-step-instrument">Do not diagnose the system directly</div><div class="g-step-action">Do not escalate visibility. Do not attempt intervention. Your first move is to map, not to act.</div><div class="g-step-signal">Any action that increases your visibility before safety is established is premature.</div></div></div>
      <div class="g-step"><div class="g-step-num">02</div><div><div class="g-step-instrument">Map indirect channels only</div><div class="g-step-action">Where does information move safely in this system? Who speaks without consequence? What language is permitted? What is unspeakable?</div><div class="g-step-signal">Map the topology of safe and unsafe speech before saying anything.</div></div></div>
      <div class="g-step"><div class="g-step-num">03</div><div><div class="g-step-instrument">Identify one safe node</div><div class="g-step-action">Find or create one person, process, or channel through which a version of the truth can move without triggering retaliation.</div><div class="g-step-signal">One safe node is enough to begin. You do not need system-wide safety to start.</div></div></div>
    </div>
    <div class="g-exit">
      <div class="g-exit-label">Exit Condition</div>
      <div class="g-exit-text">You can express a version of what is happening <strong>without exposure risk.</strong> The expression does not have to be complete — it has to be safe. When that is true, return to the Safety Check.</div>
    </div>
    <div class="g-actions">
      <button class="g-btn-primary" onclick="gGoTo('g-gate2-safety','Gate 2 · Safety Check')">Return to Safety Check</button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Precondition — Safe Mapping</div><button class="g-footer-back" onclick="gGoTo('g-gate2-safety','Gate 2 · Safety Check')">← Back</button></div>
</div>

<!-- GATE 2: PERCEPTION CHECK -->
<div class="g-screen" id="g-gate2-perception">
  <div class="g-body">
    <div class="g-entry-mark"><span></span>Gate 2 — Practitioner State · Check 2 of 4</div>
    <div class="g-title">Safety confirmed.<br>Now assess perception clarity.</div>
    <div class="g-prompt">Perception Check — Can you describe what is happening without using labels, summaries, or interpretations?</div>
    <div class="g-confirm" style="font-size:0.7rem;margin-bottom:1.2rem;">Not "the culture is toxic" or "leadership doesn't listen." Concrete events, specific instances, observable behavior. If your description requires another person to take your word for what it means — it is not clear enough yet.</div>
    <div class="g-choices">
      <button class="g-choice" onclick="gGoTo('g-precond-perception','Precondition — Signal Clarification')">
        <span class="g-choice-label">No</span>
        <span class="g-choice-text">"My description relies on labels or interpretations."</span>
        <span class="g-choice-sub">You cannot yet separate what happened from what you think it means.</span>
      </button>
      <button class="g-choice" onclick="gGoTo('g-gate2-context','Gate 2 · Check 3 of 4')">
        <span class="g-choice-label">Yes</span>
        <span class="g-choice-text">"I can describe concrete events without interpretation."</span>
        <span class="g-choice-sub">A third party could reconstruct the situation from your description alone. Proceed.</span>
      </button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Gate 2 — Perception Check</div><button class="g-footer-back" onclick="gGoTo('g-gate2-safety','Gate 2 · Safety Check')">← Back</button></div>
</div>

<!-- PRECONDITION: SIGNAL CLARIFICATION -->
<div class="g-screen" id="g-precond-perception">
  <div class="g-body">
    <div class="g-dtag perception">Precondition Loop — Signal Clarification</div>
    <div class="g-title">Slow down.<br>Separate event from meaning from judgment.</div>
    <div class="g-confirm">Perception failure is not ignorance — it is premature closure. The pattern is real, but it has been compressed into a label before it has been fully seen. This loop restores raw signal before interpretation is permitted.</div>
    <div class="g-route-label">Signal Clarification Protocol</div>
    <div class="g-route-steps">
      <div class="g-step"><div class="g-step-num">01</div><div><div class="g-step-instrument">List concrete events only</div><div class="g-step-action">Write down 3–5 specific instances. Not patterns, not summaries. What happened, when, who was involved, what was observable.</div><div class="g-step-signal">If you cannot recall specific instances — you are working from a story, not a signal.</div></div></div>
      <div class="g-step"><div class="g-step-num">02</div><div><div class="g-step-instrument">Separate the three layers</div><div class="g-step-action">For each instance: what happened (event) / what you made it mean (interpretation) / what you felt about it (judgment). Keep these three strictly separated.</div><div class="g-step-signal">You are allowed to have interpretations and judgments. You are not allowed to diagnose from them yet.</div></div></div>
      <div class="g-step"><div class="g-step-num">03</div><div><div class="g-step-instrument">Remove evaluative language</div><div class="g-step-action">Rewrite your description using only observable, behavioral, temporal language. No adjectives that require you to have already concluded something.</div><div class="g-step-signal">When your description sounds almost boring — it is probably accurate.</div></div></div>
    </div>
    <div class="g-exit">
      <div class="g-exit-label">Exit Condition</div>
      <div class="g-exit-text">A third party could reconstruct the situation from your description <strong>without interpretation.</strong> They would know what happened. They would not yet know what it means. When that is true, return to the Perception Check.</div>
    </div>
    <div class="g-actions">
      <button class="g-btn-primary" onclick="gGoTo('g-gate2-perception','Gate 2 · Perception Check')">Return to Perception Check</button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Precondition — Signal Clarification</div><button class="g-footer-back" onclick="gGoTo('g-gate2-perception','Gate 2 · Perception Check')">← Back</button></div>
</div>

<!-- GATE 2: CONTEXT CHECK -->
<div class="g-screen" id="g-gate2-context">
  <div class="g-body">
    <div class="g-entry-mark"><span></span>Gate 2 — Practitioner State · Check 3 of 4</div>
    <div class="g-title">Perception confirmed.<br>Now assess context orientation.</div>
    <div class="g-prompt">Context Check — Do you understand how this system currently holds itself together?</div>
    <div class="g-confirm" style="font-size:0.7rem;margin-bottom:1.2rem;">Not how it should work — how it actually works right now. What keeps it from collapsing? Who informally holds function? What would break first if you changed something?</div>
    <div class="g-choices">
      <button class="g-choice" onclick="gGoTo('g-precond-context','Precondition — System Mapping')">
        <span class="g-choice-label">No</span>
        <span class="g-choice-text">"I don't fully understand the system's current stabilizers."</span>
        <span class="g-choice-sub">You are at risk of breaking something you cannot see. Map before you move.</span>
      </button>
      <button class="g-choice" onclick="gGoTo('g-gate2-agency','Gate 2 · Check 4 of 4')">
        <span class="g-choice-label">Yes</span>
        <span class="g-choice-text">"I can predict what would break if I changed something."</span>
        <span class="g-choice-sub">You understand the current load-bearing structure. Proceed.</span>
      </button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Gate 2 — Context Check</div><button class="g-footer-back" onclick="gGoTo('g-gate2-perception','Gate 2 · Perception Check')">← Back</button></div>
</div>

<!-- PRECONDITION: SYSTEM MAPPING -->
<div class="g-screen" id="g-precond-context">
  <div class="g-body">
    <div class="g-dtag loop">Precondition Loop — System Mapping</div>
    <div class="g-title">You are not allowed to intervene yet.<br>Map the system before you touch it.</div>
    <div class="g-confirm">Premature intervention breaks unseen stabilizers. Every system — even a failing one — has a current logic. Disrupting it without understanding it produces collapse that looks like your fault, even when the underlying failure was already present.</div>
    <div class="g-route-label">System Mapping Protocol</div>
    <div class="g-route-steps">
      <div class="g-step"><div class="g-step-num">01</div><div><div class="g-step-instrument">Identify stabilizers</div><div class="g-step-action">What is currently preventing collapse? Formal structures, informal relationships, workarounds, cultural norms — what is load-bearing right now?</div><div class="g-step-signal">Stabilizers are often invisible until they are removed. Map them before assuming they are unimportant.</div></div></div>
      <div class="g-step"><div class="g-step-num">02</div><div><div class="g-step-instrument">Identify pressure absorbers</div><div class="g-step-action">Where is load currently being taken? Who or what is absorbing strain that the formal structure is not designed to handle?</div><div class="g-step-signal">Pressure absorbers are often the most exhausted people in the system. They are also the most critical to understand before intervening.</div></div></div>
      <div class="g-step"><div class="g-step-num">03</div><div><div class="g-step-instrument">Identify informal function holders</div><div class="g-step-action">Who actually keeps things running, regardless of their official role? Where does real authority live versus nominal authority?</div><div class="g-step-signal">Intervening on nominal structure while ignoring informal function produces visible change and real disruption.</div></div></div>
    </div>
    <div class="g-exit">
      <div class="g-exit-label">Exit Condition</div>
      <div class="g-exit-text">You can predict <strong>what would break if one stabilizer were removed.</strong> When that is true, you understand the system well enough to intervene without accidental collapse. Return to the Context Check.</div>
    </div>
    <div class="g-actions">
      <button class="g-btn-primary" onclick="gGoTo('g-gate2-context','Gate 2 · Context Check')">Return to Context Check</button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Precondition — System Mapping</div><button class="g-footer-back" onclick="gGoTo('g-gate2-context','Gate 2 · Context Check')">← Back</button></div>
</div>

<!-- GATE 2: AGENCY CHECK -->
<div class="g-screen" id="g-gate2-agency">
  <div class="g-body">
    <div class="g-entry-mark"><span></span>Gate 2 — Practitioner State · Check 4 of 4</div>
    <div class="g-title">Context confirmed.<br>Now assess agency.</div>
    <div class="g-prompt">Agency Check — Have you seen this system respond to intervention in the last 30 days?</div>
    <div class="g-confirm" style="font-size:0.7rem;margin-bottom:1.2rem;">Not a belief about whether intervention works. A concrete, observable instance of the system producing a different response because of something you did. Thirty days. Real change. Even small.</div>
    <div class="g-choices">
      <button class="g-choice" onclick="gGoTo('g-precond-agency','Precondition — Proof of Effect')">
        <span class="g-choice-label">No</span>
        <span class="g-choice-text">"I haven't seen real system response to my action recently."</span>
        <span class="g-choice-sub">Intervention exhaustion — earned, not irrational. Restore proof of effect before working at system scale.</span>
      </button>
      <button class="g-choice" onclick="gGoTo('g-gate3','Gate 3 — Failure Pattern')">
        <span class="g-choice-label">Yes</span>
        <span class="g-choice-text">"Yes — I have seen the system respond."</span>
        <span class="g-choice-sub">You have recent evidence that your action produces system response. You are calibrated. Proceed to diagnosis.</span>
      </button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Gate 2 — Agency Check</div><button class="g-footer-back" onclick="gGoTo('g-gate2-context','Gate 2 · Context Check')">← Back</button></div>
</div>

<!-- PRECONDITION: PROOF OF EFFECT -->
<div class="g-screen" id="g-precond-agency">
  <div class="g-body">
    <div class="g-dtag capacity">Precondition Loop — Proof of Effect</div>
    <div class="g-title">Do not attempt system-level work yet.<br>Restore belief through evidence.</div>
    <div class="g-confirm">Intervention exhaustion is not failure — it is accurate pattern recognition without tools or agency. The goal here is not to fix the system. It is to restore your own capacity to act by producing one observable causal change you can point to.</div>
    <div class="g-route-label">Proof of Effect Protocol</div>
    <div class="g-route-steps">
      <div class="g-step"><div class="g-step-num">01</div><div><div class="g-step-instrument">Identify the smallest interruptible thing</div><div class="g-step-action">Not the biggest problem. The smallest thing that is within your direct reach and would produce an observable different outcome.</div><div class="g-step-signal">Small scope is not a compromise — it is the correct scale for restoring agency.</div></div></div>
      <div class="g-step"><div class="g-step-num">02</div><div><div class="g-step-instrument">Run one micro-intervention</div><div class="g-step-action">It must be: reversible, low visibility, low risk, with immediate observable feedback. Do not scale up yet.</div><div class="g-step-signal">The intervention does not have to matter at system scale. It has to produce real change at local scale.</div></div></div>
      <div class="g-step"><div class="g-step-num">03</div><div><div class="g-step-instrument">Observe the outcome directly</div><div class="g-step-action">Did something different happen because of what you did? Can you point to it? Not infer it — point to it.</div><div class="g-step-signal">One observable causal change is enough. That is proof of effect. That is what you need.</div></div></div>
    </div>
    <div class="g-exit">
      <div class="g-exit-label">Exit Condition</div>
      <div class="g-exit-text">You can point to <strong>at least one causal change linked to your action.</strong> Not a belief that things are better. A specific, observable difference you produced. When that is true, return to the Agency Check.</div>
    </div>
    <div class="g-actions">
      <button class="g-btn-primary" onclick="gGoTo('g-gate2-agency','Gate 2 · Agency Check')">Return to Agency Check</button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Precondition — Proof of Effect</div><button class="g-footer-back" onclick="gGoTo('g-gate2-agency','Gate 2 · Agency Check')">← Back</button></div>
</div>

<!-- GATE 3: FAILURE PATTERN -->
<div class="g-screen" id="g-gate3">
  <div class="g-body">
    <div class="g-entry-mark"><span></span>Gate 3 — Failure Pattern Diagnosis</div>
    <div class="g-title">You are calibrated.<br>Now name the system's failure pattern.</div>
    <div class="g-confirm" style="font-size:0.72rem;margin-bottom:1.5rem;">Safety confirmed. Perception clear. Context mapped. Agency established. You are now ready to diagnose. Select the pattern that most closely describes the system's primary failure condition.</div>
    <div class="g-prompt">Which of these sounds like where the system is?</div>
    <div class="g-choices">
      <button class="g-choice" onclick="gGoTo('g-loop','Pattern 01 — Recurring Failure Loop')">
        <span class="g-choice-label">Pattern 01</span>
        <span class="g-choice-text">"We keep solving this and it comes back."</span>
        <span class="g-choice-sub">The same failure recurs despite repeated intervention. Solutions don't hold.</span>
      </button>
      <button class="g-choice" onclick="gGoTo('g-capacity','Pattern 02 — Capacity Collapse')">
        <span class="g-choice-label">Pattern 02</span>
        <span class="g-choice-text">"We can't keep people stable in the role."</span>
        <span class="g-choice-sub">Burnout, turnover, overwhelm. The system is consuming its own operators.</span>
      </button>
      <button class="g-choice" onclick="gGoTo('g-perception','Pattern 03 — Perception Failure')">
        <span class="g-choice-label">Pattern 03</span>
        <span class="g-choice-text">"We do the right thing and it still gets worse."</span>
        <span class="g-choice-sub">Intentions are sound. Actions are aligned. Outcomes continue to deteriorate.</span>
      </button>
      <button class="g-choice" onclick="gGoTo('g-signal','Pattern 04 — Signal Blindness')">
        <span class="g-choice-label">Pattern 04</span>
        <span class="g-choice-text">"We don't know what's actually happening on the ground."</span>
        <span class="g-choice-sub">Decisions are being made without reliable intelligence from the field.</span>
      </button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Gate 3 — Failure Pattern</div><button class="g-footer-back" onclick="gGoTo('g-gate2-agency','Gate 2 · Agency Check')">← Back</button></div>
</div>

<!-- LOOP FAILURE -->
<div class="g-screen" id="g-loop">
  <div class="g-body">
    <div class="g-dtag loop">Recurring Failure Loop</div>
    <div class="g-title">The system is not retaining interventions.<br>Solutions are being metabolized as events.</div>
    <div class="g-confirm">This pattern appears when a system has no mechanism to convert experience into structural change. Each intervention closes the visible symptom without touching the loop architecture that produced it. The problem returns because the conditions that generated it were never altered — only the output was managed.</div>
    <div class="g-misread"><div class="g-misread-label">Common Misread</div><div class="g-misread-text">Practitioners in this condition typically diagnose a <strong>personnel failure</strong> or <strong>execution gap.</strong> This misread produces more of the same intervention at higher intensity — which accelerates loop entrenchment rather than interrupting it.</div></div>
    <div class="g-route-label">Constrained Intervention Sequence</div>
    <div class="g-route-steps">
      <div class="g-step"><div class="g-step-num">01</div><div><div class="g-step-instrument">Loop Viability Framework</div><div class="g-step-action">Determine whether the loop is structurally interruptible. Not all loops can be corrected from inside the system generating them.</div><div class="g-step-signal">Before proceeding, you must be able to name the loop. If you cannot name it, do not move to step 02.</div></div></div>
      <div class="g-step"><div class="g-step-num">02</div><div><div class="g-step-instrument">Interruptibility Diagnostic</div><div class="g-step-action">Assess your position relative to the loop. What leverage do you actually have? Where are the real interrupt points?</div><div class="g-step-signal">If interruptibility score is low — stop. Do not deploy intervention. Move to stabilization.</div></div></div>
      <div class="g-step"><div class="g-step-num">03</div><div><div class="g-step-instrument">F&S Diagnostics I + II</div><div class="g-step-action">Run the full loop diagnostic sequence. Map where signal is entering, where it is being distorted, and where it exits without producing change.</div><div class="g-step-signal">You are looking for the distortion point — not the failure point. They are rarely the same location.</div></div></div>
      <div class="g-step"><div class="g-step-num">04</div><div><div class="g-step-instrument">Adaptive Learning Layer</div><div class="g-step-action">Build the loop's capacity to convert experience into structural adjustment. This is the intervention — not a fix, a new capability.</div><div class="g-step-signal">Loop autonomy is achieved when the system corrects itself without practitioner re-entry.</div></div></div>
    </div>
    <div class="g-exit"><div class="g-exit-label">Exit Condition — Stabilized Loop Autonomy</div><div class="g-exit-text">The loop has been interrupted when the system produces a <strong>different response to the same trigger.</strong> Not a better outcome — a different structural response.</div></div>
    <div class="g-caution"><div class="g-caution-label">Constraint</div><div class="g-caution-text">Do not attempt steps 03 and 04 before step 02 confirms interruptibility. Intervention into a non-interruptible loop from a low-leverage position produces accelerated deterioration.</div></div>
    <div class="g-actions">
      <button class="g-btn-primary" onclick="gGoTo('g-done','Path Confirmed')">I understand the path — proceed</button>
      <button class="g-btn-ghost" onclick="gGoTo('g-gate3','Gate 3 — Failure Pattern')">← Different pattern</button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Pattern 01 — Recurring Failure Loop</div><button class="g-footer-back" onclick="gGoTo('g-gate3','Gate 3')">← Back</button></div>
</div>

<!-- CAPACITY COLLAPSE -->
<div class="g-screen" id="g-capacity">
  <div class="g-body">
    <div class="g-dtag capacity">Capacity Collapse</div>
    <div class="g-title">The system is consuming its operators.<br>Stabilization failure is structural, not personal.</div>
    <div class="g-confirm">This pattern appears when a system's operational demands exceed the structural capacity available to meet them — and the gap is being filled by human absorption. Turnover, burnout, and overwhelm are not personnel problems. They are load readings.</div>
    <div class="g-misread"><div class="g-misread-label">Common Misread</div><div class="g-misread-text">Practitioners typically diagnose a <strong>resilience failure</strong> or <strong>culture problem</strong> and invest in wellness programs or supervision increases. This addresses the symptom while the structural load condition continues generating casualties.</div></div>
    <div class="g-route-label">Constrained Intervention Sequence</div>
    <div class="g-route-steps">
      <div class="g-step"><div class="g-step-num">01</div><div><div class="g-step-instrument">Conditions Layer</div><div class="g-step-action">Assess current field conditions before any other move. Is the environment workable? Is intervention possible from this position at this time?</div><div class="g-step-signal">If conditions are critically degraded — triage first. Do not run diagnostics on a system in acute collapse.</div></div></div>
      <div class="g-step"><div class="g-step-num">02</div><div><div class="g-step-instrument">Capacity Mapping Tool</div><div class="g-step-action">Map what structural capacity actually exists versus what is being demanded. Quantify the gap. Name what is filling it.</div><div class="g-step-signal">You are not assessing people's capability. You are assessing structural load distribution.</div></div></div>
      <div class="g-step"><div class="g-step-num">03</div><div><div class="g-step-instrument">Harm as Feedback Protocol</div><div class="g-step-action">Treat each instance of burnout, departure, or breakdown as a signal about system design — not individual failure. Convert harm into diagnostic data.</div><div class="g-step-signal">The departure pattern will tell you where the structural fault line is if you read it correctly.</div></div></div>
      <div class="g-step"><div class="g-step-num">04</div><div><div class="g-step-instrument">Structural Capacity Model + Trust Infrastructure</div><div class="g-step-action">Redesign the load distribution. Build the infrastructure that allows the system to hold its operators rather than consume them.</div><div class="g-step-signal">Stability is achieved when the system can sustain operators across a full cycle without requiring extraordinary personal expenditure.</div></div></div>
    </div>
    <div class="g-exit"><div class="g-exit-label">Exit Condition — Stabilized Loop Autonomy</div><div class="g-exit-text">Capacity stabilization is achieved when <strong>retention normalizes without increasing individual burden.</strong> Not when people say they feel better — when the structural load has redistributed.</div></div>
    <div class="g-caution"><div class="g-caution-label">Constraint</div><div class="g-caution-text">Do not begin redesign before the Conditions Layer confirms the field is workable. Redesigning a system in acute collapse produces additional instability. Triage first.</div></div>
    <div class="g-actions">
      <button class="g-btn-primary" onclick="gGoTo('g-done','Path Confirmed')">I understand the path — proceed</button>
      <button class="g-btn-ghost" onclick="gGoTo('g-gate3','Gate 3 — Failure Pattern')">← Different pattern</button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Pattern 02 — Capacity Collapse</div><button class="g-footer-back" onclick="gGoTo('g-gate3','Gate 3')">← Back</button></div>
</div>

<!-- PERCEPTION FAILURE -->
<div class="g-screen" id="g-perception">
  <div class="g-body">
    <div class="g-dtag perception">Perception Failure</div>
    <div class="g-title">The diagnosis is wrong.<br>The system is being read through a distorted frame.</div>
    <div class="g-confirm">This pattern appears when a system's intervention logic is sound but the causal model underneath it is incorrect. The right action is being applied to the wrong problem. Outcomes continue to deteriorate not because of execution failure but because the perception of the system is fundamentally misaligned with what is actually occurring.</div>
    <div class="g-misread"><div class="g-misread-label">Common Misread</div><div class="g-misread-text">Practitioners typically diagnose a <strong>commitment failure</strong> or <strong>resource deficit</strong> and escalate investment in the wrong causal model. The confidence this generates is part of the danger.</div></div>
    <div class="g-route-label">Constrained Intervention Sequence</div>
    <div class="g-route-steps">
      <div class="g-step"><div class="g-step-num">01</div><div><div class="g-step-instrument">Verification Intake</div><div class="g-step-action">Verify your current causal model. What do you believe is causing the failure? What evidence supports it? What contradicts it?</div><div class="g-step-signal">You are not verifying facts. You are verifying your reading of the system. These are different operations.</div></div></div>
      <div class="g-step"><div class="g-step-num">02</div><div><div class="g-step-instrument">Signal Intake Layer</div><div class="g-step-action">Re-open signal intake. What is the system actually producing? Set aside interpretation and read the raw output.</div><div class="g-step-signal">Look for the signal you have been discounting. The misread is almost always about what is being filtered out.</div></div></div>
      <div class="g-step"><div class="g-step-num">03</div><div><div class="g-step-instrument">Power Loop Field Diagnostic</div><div class="g-step-action">Map the actual power architecture of the system. Where does authority live? Where does information travel? Where do they diverge?</div><div class="g-step-signal">Perception failure is frequently a power map failure. The system looks different from different positions inside it.</div></div></div>
      <div class="g-step"><div class="g-step-num">04</div><div><div class="g-step-instrument">Coherence Development Map</div><div class="g-step-action">Rebuild the causal model from corrected signal. Design intervention from the new diagnosis — not the original one.</div><div class="g-step-signal">Correct diagnosis is confirmed when you can predict system behavior accurately before intervening.</div></div></div>
    </div>
    <div class="g-exit"><div class="g-exit-label">Exit Condition — Stabilized Loop Autonomy</div><div class="g-exit-text">Perception failure is resolved when <strong>your causal model produces accurate predictions.</strong> Not when outcomes improve — when you understand why they are improving and can anticipate what happens next.</div></div>
    <div class="g-caution"><div class="g-caution-label">Constraint</div><div class="g-caution-text">Do not design new interventions before completing steps 01 and 02. Designing from a corrupted causal model produces interventions that are coherent internally but wrong in practice.</div></div>
    <div class="g-actions">
      <button class="g-btn-primary" onclick="gGoTo('g-done','Path Confirmed')">I understand the path — proceed</button>
      <button class="g-btn-ghost" onclick="gGoTo('g-gate3','Gate 3 — Failure Pattern')">← Different pattern</button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Pattern 03 — Perception Failure</div><button class="g-footer-back" onclick="gGoTo('g-gate3','Gate 3')">← Back</button></div>
</div>

<!-- SIGNAL BLINDNESS -->
<div class="g-screen" id="g-signal">
  <div class="g-body">
    <div class="g-dtag signal">Signal Blindness</div>
    <div class="g-title">Authority and intelligence have separated.<br>The system is deciding without field data.</div>
    <div class="g-confirm">This pattern appears when decision-making authority is structurally insulated from the information required to make decisions well. The gap between what leadership believes is happening and what is actually happening has become operationally significant.</div>
    <div class="g-misread"><div class="g-misread-label">Common Misread</div><div class="g-misread-text">Practitioners typically diagnose a <strong>communication failure</strong> and create more reporting channels. This misread addresses signal infrastructure without asking why signal is not moving through existing infrastructure — which is almost always a <strong>trust or power architecture problem.</strong></div></div>
    <div class="g-route-label">Constrained Intervention Sequence</div>
    <div class="g-route-steps">
      <div class="g-step"><div class="g-step-num">01</div><div><div class="g-step-instrument">Signal Intake Layer</div><div class="g-step-action">Open a direct signal intake process that bypasses existing reporting infrastructure. You need to hear what is actually happening — not what is being transmitted through compromised channels.</div><div class="g-step-signal">The signal not moving through official channels is almost always the most important signal in the system.</div></div></div>
      <div class="g-step"><div class="g-step-num">02</div><div><div class="g-step-instrument">Power Loop Field Diagnostic</div><div class="g-step-action">Map where authority sits and where information is being stopped. Find the points where signal enters the system but does not travel upward — and identify what is blocking it.</div><div class="g-step-signal">Signal blockage is rarely accidental. Map the incentive structure around silence.</div></div></div>
      <div class="g-step"><div class="g-step-num">03</div><div><div class="g-step-instrument">Institutional Response Map</div><div class="g-step-action">Document how the institution has historically responded to field signal. Is it safe to send signal upward? What has happened to people who have done so?</div><div class="g-step-signal">You cannot build signal infrastructure on top of a punishment architecture. The trust layer must be addressed first.</div></div></div>
      <div class="g-step"><div class="g-step-num">04</div><div><div class="g-step-instrument">Trust Infrastructure Framework</div><div class="g-step-action">Build the conditions under which signal can travel safely. This is not a communication redesign. It is a trust architecture build.</div><div class="g-step-signal">Signal blindness is resolved when field intelligence reaches decision points without distortion — consistently, not occasionally.</div></div></div>
    </div>
    <div class="g-exit"><div class="g-exit-label">Exit Condition — Stabilized Loop Autonomy</div><div class="g-exit-text">Signal blindness is resolved when <strong>decision-makers can accurately describe field conditions without being briefed.</strong> Not when more reports are submitted — when intelligence is arriving with enough fidelity that decisions begin to shift.</div></div>
    <div class="g-caution"><div class="g-caution-label">Constraint</div><div class="g-caution-text">Do not build new signal infrastructure before completing step 03. New channels installed on top of a broken trust architecture will be used performatively — producing signal volume without signal integrity. The result is worse than silence.</div></div>
    <div class="g-actions">
      <button class="g-btn-primary" onclick="gGoTo('g-done','Path Confirmed')">I understand the path — proceed</button>
      <button class="g-btn-ghost" onclick="gGoTo('g-gate3','Gate 3 — Failure Pattern')">← Different pattern</button>
    </div>
  </div>
  <div class="guide-footer"><div class="g-footer-note">Pattern 04 — Signal Blindness</div><button class="g-footer-back" onclick="gGoTo('g-gate3','Gate 3')">← Back</button></div>
</div>

<!-- DONE -->
<div class="g-screen" id="g-done">
  <div class="g-body">
    <div class="g-entry-mark"><span></span>Path Confirmed</div>
    <div class="g-title">Your path is set.<br>Work the sequence. Do not skip steps.</div>
    <div class="g-sub">The sequence is not bureaucracy. Each step produces the conditions required for the next step to work. Skipping produces interventions that are coherent in isolation and wrong in practice.</div>
    <div class="g-misread" style="border-color: var(--signal-dim); background: var(--signal-faint);">
      <div class="g-misread-label" style="color: var(--signal);">One Operative Principle</div>
      <div class="g-misread-text"><strong style="color:var(--signal);font-family:'IBM Plex Mono',monospace;font-size:0.68rem;">You are a single-thread perception engine inside a multi-thread constraint environment.</strong><br><br>The system will push you toward urgency, toward consensus, toward the intervention that feels most immediately satisfying. The guide held your perception steady long enough to find the correct diagnostic frame. Your job now is to hold it steady long enough to work the path.</div>
    </div>
    <div class="g-exit">
      <div class="g-exit-label">When the guide's job is done</div>
      <div class="g-exit-text">The guide exits when <strong>the loop is running and self-correcting without your re-entry.</strong> That is stabilized loop autonomy. You will know you are there when the system surprises you — not with failure, but with its own correction.</div>
    </div>
    <div class="g-actions">
      <button class="g-btn-primary" onclick="gGoTo('g-entry','Gate 1')">Start a new session</button>
    </div>
  </div>
  <div class="guide-footer">
    <div class="g-footer-note">Field & Signal — Practitioner Guide — v2.0 — April 2026</div>
    <div class="g-footer-note">fieldsignal.org</div>
  </div>
</div>
```

  </div>
</div>

<script>
  // NAV SCROLL
  function scrollTo(id, btn) {
    document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
    document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
    btn.classList.add('active');
  }

  // Update nav active state on scroll
  window.addEventListener('scroll', () => {
    const sections = ['section-schematic','section-layer0','section-guide'];
    const links = document.querySelectorAll('.nav-link');
    let current = 0;
    sections.forEach((id, i) => {
      const el = document.getElementById(id);
      if (el && window.scrollY >= el.offsetTop - 80) current = i;
    });
    links.forEach((l, i) => l.classList.toggle('active', i === current));
  });

  // GUIDE NAVIGATION
  function gGoTo(id, status) {
    document.querySelectorAll('.g-screen').forEach(s => s.classList.remove('active'));
    const target = document.getElementById(id);
    target.classList.add('active');
    document.getElementById('guide-status').textContent = status || '';
    target.scrollIntoView({ behavior: 'smooth', block: 'start' });

    // re-trigger animations
    target.querySelectorAll('.g-body > *').forEach(el => {
      el.style.animation = 'none';
      el.offsetHeight;
      el.style.animation = '';
    });
  }
</script>

</body>
</html>