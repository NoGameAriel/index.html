// ── STATE ──
let responses = {}; // axiomId -> questionIdx -> value (0-1)
let axiomScores = {}; // axiomId -> s_i
let completedAxioms = new Set();
let diagnosticStarted = false;

// ── SCORING MAP ──
function responseToScore(options, selectedIdx) {
  const n = options.length;
  if (n === 2) return selectedIdx === 0 ? 1.0 : 0.0;
  if (n === 3) return [1.0, 0.5, 0.0][selectedIdx] ?? 0.5;
  if (n === 4) return [1.0, 0.65, 0.15, 0.4][selectedIdx] ?? 0.5;
  return 0.5;
}

// Some questions are inverted (bad answer = index 0)
const INVERTED_QUESTIONS = {
  '2-3': true, // "are there populations bearing cost with no representation" - No is good
  '3-1': true, // "can operators suppress" - No is good
  '5-3': true, // "is there lock-in config" - No is good
  '6-2': true, // "mandatory depleting participation" - No is good
  '7-2': true, // "have metrics driven harm" - No is good
  '7-3': true, // "does system reward metric gaming" - No is good
};

function getQuestionScore(axiomId, qIdx, optionIdx, options) {
  const key = `${axiomId}-${qIdx}`;
  let score = responseToScore(options, optionIdx);
  if (INVERTED_QUESTIONS[key]) score = 1.0 - score;
  return score;
}

function computeAxiomScore(axiomId) {
  const ax = AXIOMS.find(a => a.id === axiomId);
  const qResponses = responses[axiomId] || {};
  const qCount = ax.questions.length;
  let answered = 0, total = 0;
  for (let i = 0; i < qCount; i++) {
    if (qResponses[i] !== undefined) {
      total += qResponses[i];
      answered++;
    }
  }
  if (answered === 0) return null;
  return total / answered;
}

function scoreColor(s) {
  if (s >= 0.65) return 'good';
  if (s >= 0.40) return 'warn';
  return 'bad';
}

// ── BUILD UI ──
function buildProgressDots() {
  const container = document.getElementById('progress-dots');
  container.innerHTML = '';
  AXIOMS.forEach((ax, i) => {
    const dot = document.createElement('div');
    dot.className = 'dot';
    dot.id = `dot-${ax.id}`;
    dot.title = ax.name;
    dot.onclick = () => {
      const mod = document.getElementById(`axiom-mod-${ax.id}`);
      if (mod) mod.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };
    container.appendChild(dot);
  });
}

function buildAxiomModules() {
  const container = document.getElementById('axiom-modules');
  container.innerHTML = '';
  AXIOMS.forEach((ax, idx) => {
    const mod = document.createElement('div');
    mod.className = 'axiom-module';
    mod.id = `axiom-mod-${ax.id}`;
    if (idx === 0) mod.classList.add('unlocked', 'active-module');

    mod.innerHTML = `
      <div class="axiom-header" onclick="toggleAxiom(${ax.id})">
        <div class="axiom-num-badge">A-0${ax.id}</div>
        <div class="axiom-title-text">
          <div class="axiom-name">${ax.name}</div>
          <div class="axiom-sub">${ax.sub}</div>
        </div>
        <div class="axiom-score-display">
          <div class="s-value" id="s-val-${ax.id}">—</div>
          <div class="d-value" id="d-val-${ax.id}">D = —</div>
        </div>
      </div>
      <div class="axiom-body ${idx === 0 ? 'open' : ''}" id="axiom-body-${ax.id}">
        ${ax.questions.map((q, qi) => buildQuestion(ax.id, qi, q)).join('')}
        <div class="drift-bar-container">
          <div class="drift-bar-label">
            <span>0 — Non-admissible</span>
            <span>τ = ${ax.tau}</span>
            <span>1.0 — Stable</span>
          </div>
          <div class="drift-track">
            <div class="drift-fill" id="drift-fill-${ax.id}" style="width:0%"></div>
            <div class="threshold-marker" style="left: ${ax.tau * 100}%"></div>
          </div>
        </div>
      </div>
    `;
    container.appendChild(mod);
  });
}

function buildQuestion(axiomId, qi, q) {
  const opts = q.options.map((opt, oi) => 
    `<button class="resp-btn" id="resp-${axiomId}-${qi}-${oi}" onclick="selectResponse(${axiomId}, ${qi}, ${oi}, '${opt.toLowerCase().replace(/[^a-z]/g,'')}')">${opt}</button>`
  ).join('');

  return `
    <div class="question-block" id="qblock-${axiomId}-${qi}">
      <div class="question-text">${q.text}</div>
      ${q.context ? `<div class="question-context">${q.context}</div>` : ''}
      <div class="response-options">${opts}</div>
    </div>
  `;
}

function selectResponse(axiomId, qi, optionIdx, optStr) {
  const ax = AXIOMS.find(a => a.id === axiomId);
  const q = ax.questions[qi];

  // Clear previous selection in this question
  q.options.forEach((_, oi) => {
    const btn = document.getElementById(`resp-${axiomId}-${qi}-${oi}`);
    if (btn) btn.className = 'resp-btn';
  });

  // Mark selected
  const selected = document.getElementById(`resp-${axiomId}-${qi}-${optionIdx}`);
  if (selected) {
    const firstWord = optStr.substring(0, 2);
    let cls = 'selected-partial';
    if (['ye', 'no'].includes(firstWord)) {
      // Determine if this is a good or bad answer
      const score = getQuestionScore(axiomId, qi, optionIdx, q.options);
      cls = score >= 0.7 ? 'selected-yes' : score <= 0.3 ? 'selected-no' : 'selected-partial';
    }
    selected.classList.add(cls);
  }

  if (!responses[axiomId]) responses[axiomId] = {};
  responses[axiomId][qi] = getQuestionScore(axiomId, qi, optionIdx, q.options);

  updateAxiomDisplay(axiomId);
  checkAxiomComplete(axiomId);
}

function updateAxiomDisplay(axiomId) {
  const ax = AXIOMS.find(a => a.id === axiomId);
  const s = computeAxiomScore(axiomId);
  if (s === null) return;

  const D = s - ax.tau;
  const sVal = document.getElementById(`s-val-${axiomId}`);
  const dVal = document.getElementById(`d-val-${axiomId}`);
  const dFill = document.getElementById(`drift-fill-${axiomId}`);

  if (sVal) {
    sVal.textContent = s.toFixed(2);
    sVal.className = 's-value ' + scoreColor(s);
  }
  if (dVal) {
    dVal.textContent = `D = ${D >= 0 ? '+' : ''}${D.toFixed(2)}`;
    dVal.className = 'd-value ' + (D >= 0 ? 'pass' : 'fail');
  }
  if (dFill) {
    dFill.style.width = (s * 100) + '%';
    dFill.style.background = s < ax.tau ? 'var(--red-bright)' : s < 0.6 ? 'var(--amber-bright)' : 'var(--green)';
  }

  axiomScores[axiomId] = s;
}

function checkAxiomComplete(axiomId) {
  const ax = AXIOMS.find(a => a.id === axiomId);
  const qResponses = responses[axiomId] || {};
  const answered = Object.keys(qResponses).length;
  if (answered >= ax.questions.length) {
    completedAxioms.add(axiomId);
    updateDot(axiomId);
    updateProgress();

    const mod = document.getElementById(`axiom-mod-${axiomId}`);
    const s = axiomScores[axiomId] ?? 0;
    if (mod) {
      mod.classList.remove('active-module');
      mod.classList.add(s < ax.tau ? 'complete-fail' : 'complete-pass');
    }

    // Unlock next
    const idx = AXIOMS.findIndex(a => a.id === axiomId);
    if (idx < AXIOMS.length - 1) {
      const nextMod = document.getElementById(`axiom-mod-${AXIOMS[idx+1].id}`);
      if (nextMod) {
        nextMod.classList.add('unlocked', 'active-module');
        setTimeout(() => nextMod.scrollIntoView({ behavior: 'smooth', block: 'start' }), 300);
      }
    }

    if (completedAxioms.size === AXIOMS.length) {
      showGateResult();
    }
  }
}

function updateDot(axiomId) {
  const ax = AXIOMS.find(a => a.id === axiomId);
  const dot = document.getElementById(`dot-${axiomId}`);
  if (!dot) return;
  const s = axiomScores[axiomId] ?? 0;
  dot.className = 'dot ' + (s < ax.tau ? 'failed' : 'complete');
}

function updateProgress() {
  const frac = document.getElementById('progress-fraction');
  if (frac) frac.textContent = `${completedAxioms.size} / 8`;
}

function toggleAxiom(axiomId) {
  const body = document.getElementById(`axiom-body-${axiomId}`);
  if (body) body.classList.toggle('open');
}

// ── GATE RESULT ──
function showGateResult() {
  const failures = AXIOMS.filter(ax => (axiomScores[ax.id] ?? 0) < ax.tau);
  const pass = failures.length === 0;

  const gateEl = document.getElementById('gate-result');
  const verdict = document.getElementById('gate-verdict-text');
  const verdictSub = document.getElementById('gate-verdict-sub');
  const summaryGrid = document.getElementById('axiom-summary-grid');
  const flagContainer = document.getElementById('rejection-flags-container');
  const narrative = document.getElementById('gate-narrative');
  const statusEl = document.getElementById('header-gate-status');

  gateEl.style.display = 'block';
  gateEl.className = pass ? 'pass' : 'fail';

  verdict.className = 'gate-verdict ' + (pass ? 'pass' : 'fail');
  verdict.textContent = pass ? 'System Admissible Under CPT' : 'System Non-Admissible Under CPT';

  verdictSub.textContent = pass
    ? 'All axioms above threshold. F&S drift analysis may proceed.'
    : `${failures.length} rejection condition${failures.length > 1 ? 's' : ''} triggered. CPT gate closed. Analysis cannot proceed.`;

  statusEl.textContent = pass ? 'ADMISSIBLE' : 'NON-ADMISSIBLE';
  statusEl.className = 'gate-status ' + (pass ? 'pass' : 'fail');

  // Summary grid
  summaryGrid.innerHTML = AXIOMS.map(ax => {
    const s = axiomScores[ax.id] ?? 0;
    const D = s - ax.tau;
    const cls = s < ax.tau ? 'fail' : s < 0.6 ? 'warn' : 'pass';
    return `
      <div class="axiom-summary-item">
        <div class="asi-name">A-0${ax.id} · ${ax.name.split(' ').slice(0,3).join(' ')}</div>
        <div class="asi-score ${cls}">s = ${s.toFixed(2)}</div>
        <div class="asi-d">D = ${D >= 0 ? '+' : ''}${D.toFixed(2)} · τ = ${ax.tau}</div>
      </div>
    `;
  }).join('');

  // Rejection flags
  if (failures.length > 0) {
    flagContainer.innerHTML = '<div style="font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.12em; color: var(--red-bright); margin-bottom: 0.75rem;">REJECTION CONDITIONS TRIGGERED</div>' +
      failures.map(ax => `
        <div class="rejection-flag">
          <div class="rf-icon">▶ FAIL</div>
          <div class="rf-text"><strong>${ax.rejectionLabel}</strong> — Axiom ${ax.id}: ${ax.name}. s<sub>${ax.id}</sub> = ${(axiomScores[ax.id]??0).toFixed(2)}, τ = ${ax.tau}, D = ${((axiomScores[ax.id]??0) - ax.tau).toFixed(2)}.</div>
        </div>
      `).join('');
  }

  // Narrative
  const sysName = document.getElementById('sys-name').value || 'the evaluated system';
  const weakest = AXIOMS.reduce((min, ax) => (axiomScores[ax.id] ?? 0) < (axiomScores[min.id] ?? 1) ? ax : min);
  const strongest = AXIOMS.reduce((max, ax) => (axiomScores[ax.id] ?? 0) > (axiomScores[max.id] ?? 0) ? ax : max);

  if (pass) {
    const avgS = Object.values(axiomScores).reduce((a,b) => a+b, 0) / 8;
    const atRisk = AXIOMS.filter(ax => (axiomScores[ax.id] ?? 0) < ax.tau + 0.15);
    narrative.innerHTML = `
      <strong>${sysName}</strong> is structurally admissible under CPT. Mean s̄ = ${avgS.toFixed(2)}. 
      Strongest axis: <em>${strongest.name}</em> (s = ${(axiomScores[strongest.id]??0).toFixed(2)}). 
      ${atRisk.length > 0 
        ? `<br><br>Axes approaching threshold (within 0.15 of τ): <em>${atRisk.map(a => a.name).join(', ')}</em>. F&S drift monitoring recommended. These represent early-stage vulnerability, not current failure.`
        : 'All axes demonstrate adequate distance from threshold boundaries. System is stable under current conditions. Continued F&S monitoring advised.'
      }
    `;
  } else {
    narrative.innerHTML = `
      <strong>${sysName}</strong> is non-admissible under CPT. Gate is closed. The identified rejection conditions represent structural impossibilities under condition preservation logic — not design weaknesses to be optimized, but fundamental architectural violations. 
      <br><br>
      Non-admissibility does not imply moral judgment. It means the system, as currently constituted, cannot sustain the conditions it depends on without displacing degradation across hidden boundaries. Intervention must be structural, not incremental.
      <br><br>
      <em>Strongest surviving axis: ${strongest.name} (s = ${(axiomScores[strongest.id]??0).toFixed(2)}). This represents the most viable foundation for any rebuild or parallel-system design effort.</em>
    `;
  }

  gateEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ── INIT ──
function beginDiagnostic() {
  const name = document.getElementById('sys-name').value.trim();
  if (!name) {
    document.getElementById('sys-name').focus();
    document.getElementById('sys-name').style.borderColor = 'var(--amber)';
    return;
  }
  diagnosticStarted = true;
  document.getElementById('axiom-section-header').style.display = 'block';
  buildAxiomModules();
  updateProgress();
  document.getElementById('axiom-modules').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function resetInstrument() {
  responses = {};
  axiomScores = {};
  completedAxioms = new Set();
  diagnosticStarted = false;
  document.getElementById('sys-name').value = '';
  document.getElementById('sys-purpose').value = '';
  document.getElementById('sys-domain').value = '';
  document.getElementById('sys-name').style.borderColor = '';
  document.getElementById('axiom-section-header').style.display = 'none';
  document.getElementById('axiom-modules').innerHTML = '';
  document.getElementById('gate-result').style.display = 'none';
  document.getElementById('header-gate-status').textContent = 'AWAITING INPUT';
  document.getElementById('header-gate-status').className = 'gate-status';
  updateProgress();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// Build initial progress dots
buildProgressDots();
</script>

