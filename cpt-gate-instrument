  },
  {
    id: 7,
    name: "Value-Reality Alignment",
    sub: "Axiom 07 · τ₇ = 0.35",
    tau: 0.35,
    rejectionLabel: "Unbounded Cost Displacement (Value layer)",
    questions: [
      {
        text: "Do the system's internal success metrics correspond to real-world outcomes for the populations and environments it affects?",
        context: "Misalignment example: profit as success metric where ecological degradation is the actual outcome.",
        options: ["Yes, tightly aligned", "Partially aligned", "No — internal metrics diverge from actual effects"]
      },
      {
